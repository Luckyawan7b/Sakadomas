###############################################################################
# Smart-Saka — Environment Variables
# Salin file ini ke .env lalu isi dengan nilai nyata:
#   cp .env.example .env
#   php artisan key:generate
###############################################################################

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Smart-Saka"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, paling mudah untuk development)
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# MySQL (uncomment jika menggunakan MySQL)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=smart_saka
# DB_USERNAME=root
# DB_PASSWORD=

# PostgreSQL (uncomment jika menggunakan PostgreSQL)
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=smart_saka
# DB_USERNAME=postgres
# DB_PASSWORD=

# ── Caching / Sessions / Queues ──────────────────────────────────────────────
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@smart-saka.id"
MAIL_FROM_NAME="${APP_NAME}"

# ── Smart-Saka — Konfigurasi bisnis ──────────────────────────────────────────
# Nomor WhatsApp format internasional (tanpa + atau -)
# Contoh: 6281234567890  (62 = Indonesia, 81234567890 = nomor lokal)
SMARTSAKA_WA_NUMBER=6281234567890

SMARTSAKA_NAME="Smart-Saka"
SMARTSAKA_EMAIL="hello@smart-saka.id"
SMARTSAKA_PHONE="+62812XXXXXXXX"
SMARTSAKA_FOUNDED=2016

SMARTSAKA_ADDRESS_STREET="Jl. Sakadomas"
SMARTSAKA_ADDRESS_CITY="Jember"
SMARTSAKA_ADDRESS_PROVINCE="Jawa Timur"
SMARTSAKA_ADDRESS_ZIP="68122"

# Koordinat GPS untuk JSON-LD structured data
SMARTSAKA_LAT=-8.3015
SMARTSAKA_LNG=113.5492

# URL embed Google Maps (ambil dari Google Maps > Share > Embed a map > Copy HTML, ambil nilai src)
SMARTSAKA_MAPS_SRC="https://www.google.com/maps/embed?pb=..."

# URL media sosial
SMARTSAKA_INSTAGRAM="https://www.instagram.com/smartsaka"
SMARTSAKA_FACEBOOK="https://www.facebook.com/smartsaka"
SMARTSAKA_TIKTOK=""
SMARTSAKA_YOUTUBE=""

# Path gambar Open Graph relatif dari /public (wajib 1200x630px)
SMARTSAKA_OG_IMAGE="/images/og-smart-saka.jpg"

# ── Google OAuth (Socialite) — opsional ──────────────────────────────────────
# Aktifkan setelah: composer require laravel/socialite
# Buat credentials di: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# ── Vite ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
